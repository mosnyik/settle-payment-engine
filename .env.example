# =============================================================================
# PAYMENT ENGINE - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values.
# Variables marked [REQUIRED] must be set for the system to function.
# Variables marked [OPTIONAL] have sensible defaults.
#
# Usage locations reference src/config/index.ts unless otherwise noted.
# =============================================================================

# =============================================================================
# SERVER
# =============================================================================

# [OPTIONAL] Port the Express server listens on
# Used in: src/index.ts
PORT=3500

# [OPTIONAL] Node environment (development, production, test)
# Used in: src/lib/mysql.ts, src/security/middleware/securityHeaders.ts
NODE_ENV=development

# =============================================================================
# DATABASE (MySQL)
# =============================================================================
# Used in: src/config/index.ts -> database config, src/lib/mysql.ts

# [REQUIRED] MySQL host
DB_HOST=localhost

# [OPTIONAL] MySQL port
DB_PORT=3306

# [REQUIRED] MySQL username
DB_USER=root

# [REQUIRED] MySQL password
DB_PASSWORD=

# [REQUIRED] MySQL database name
DB_NAME=2settle

# =============================================================================
# ADMIN AUTHENTICATION
# =============================================================================

# [REQUIRED] Secret token for admin endpoints (/v1/admin/*)
# Used in: src/security/middleware/adminAuth.ts
# Generate with: openssl rand -hex 32
ADMIN_SECRET=your-secure-admin-secret-here

# =============================================================================
# EXTERNAL APIs
# =============================================================================

# [REQUIRED for crypto prices] CoinMarketCap API key
# Used in: src/services/payment-engine/rate/coinmarketcap.service.ts
# Get from: https://coinmarketcap.com/api/
COINMARKETCAP_API_KEY=

# [REQUIRED for bank verification] NUBAN API key
# Used in: src/routes/bank.routes.ts
NUBAN_API_KEY=

# =============================================================================
# HD WALLET
# =============================================================================
# Hierarchical Deterministic wallet for generating unique deposit addresses.
# If disabled, falls back to legacy wallet pool.
# Used in: src/services/payment-engine/hd-wallet/

# [OPTIONAL] Enable HD wallet address derivation
HD_WALLET_ENABLED=false

# [REQUIRED if HD_WALLET_ENABLED=true] Encrypted seed phrase
# Generate with: node generate-hd-keys.js
HD_SEED_PHRASE_ENCRYPTED=

# [REQUIRED if HD_WALLET_ENABLED=true] 64-character hex key for decrypting seed
# Generate with: node generate-hd-keys.js
HD_SEED_ENCRYPTION_KEY=

# =============================================================================
# HOT WALLETS (Sweep Destinations)
# =============================================================================
# Addresses where swept funds are sent. Required if SWEEPER_ENABLED=true.
# Used in: src/services/payment-engine/sweeper/

# [REQUIRED if sweeping BTC] Bitcoin hot wallet (native segwit bc1q...)
HOT_WALLET_BITCOIN=

# [REQUIRED if sweeping ETH/ERC20] Ethereum hot wallet (0x...)
HOT_WALLET_ETHEREUM=

# [REQUIRED if sweeping TRX/TRC20] Tron hot wallet (T...)
HOT_WALLET_TRON=

# =============================================================================
# SWEEPER
# =============================================================================
# Automatically sweeps deposited funds from HD-derived addresses to hot wallets.
# Used in: src/services/payment-engine/sweeper/

# [OPTIONAL] Enable automatic fund sweeping
SWEEPER_ENABLED=false

# [OPTIONAL] Max retry attempts for failed sweeps
SWEEPER_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# RPC Endpoints for Sweeper
# -----------------------------------------------------------------------------
# Used in: src/services/payment-engine/sweeper/chains/

# [OPTIONAL] Ethereum RPC endpoint (for ETH and ERC20 sweeps)
ETHEREUM_RPC_URL=https://eth.llamarpc.com

# [OPTIONAL] BSC RPC endpoint (for BNB and BEP20 sweeps)
BSC_RPC_URL=https://bsc-dataseed.binance.org

# [OPTIONAL] Polygon RPC endpoint (if supporting Polygon)
# POLYGON_RPC_URL=

# [OPTIONAL] Base RPC endpoint (if supporting Base)
# BASE_RPC_URL=

# -----------------------------------------------------------------------------
# Minimum Sweep Thresholds
# -----------------------------------------------------------------------------
# Don't sweep amounts below these values (saves gas fees).
# Used in: src/services/payment-engine/sweeper/

# [OPTIONAL] Minimum BTC to sweep
SWEEP_MIN_BTC=0.0001

# [OPTIONAL] Minimum ETH to sweep
SWEEP_MIN_ETH=0.001

# [OPTIONAL] Minimum BNB to sweep
SWEEP_MIN_BNB=0.01

# [OPTIONAL] Minimum TRX to sweep
SWEEP_MIN_TRX=10

# [OPTIONAL] Minimum USDT to sweep (all networks)
SWEEP_MIN_USDT=1

# [OPTIONAL] Minimum USDC to sweep (all networks)
SWEEP_MIN_USDC=1

# =============================================================================
# DEPOSIT WATCHER
# =============================================================================
# Monitors blockchain for incoming deposits to payment addresses.
# Used in: src/services/payment-engine/watcher/

# [OPTIONAL] Enable deposit watching
WATCHER_ENABLED=false

# [OPTIONAL] Amount tolerance for deposit matching (0.02 = 2%)
WATCHER_AMOUNT_TOLERANCE=0.02

# [OPTIONAL] Max payment sessions to check per poll cycle
WATCHER_MAX_SESSIONS_PER_POLL=100

# -----------------------------------------------------------------------------
# Blockchain API Keys
# -----------------------------------------------------------------------------
# Required for their respective chains when WATCHER_ENABLED=true.
# Used in: src/services/payment-engine/watcher/chains/

# [REQUIRED for ETH/ERC20] Etherscan API key
# Get from: https://etherscan.io/apis
ETHERSCAN_API_KEY=

# [REQUIRED for BSC/BEP20] BscScan API key
# Get from: https://bscscan.com/apis
BSCSCAN_API_KEY=

# [OPTIONAL for TRX/TRC20] TronGrid API key (free tier works without key)
# Get from: https://www.trongrid.io/
TRONGRID_API_KEY=

# -----------------------------------------------------------------------------
# Watcher API URLs (Override defaults if needed)
# -----------------------------------------------------------------------------

# [OPTIONAL] Blockstream API URL for Bitcoin
# BLOCKSTREAM_API_URL=https://blockstream.info/api

# [OPTIONAL] Etherscan API URL (v2 API)
# ETHERSCAN_API_URL=https://api.etherscan.io/v2/api

# [OPTIONAL] BscScan API URL (v2 API)
# BSCSCAN_API_URL=https://api.etherscan.io/v2/api

# [OPTIONAL] TronGrid API URL
# TRONGRID_API_URL=https://api.trongrid.io

# -----------------------------------------------------------------------------
# Watcher Polling Intervals (milliseconds)
# -----------------------------------------------------------------------------
# Lower = faster detection but more API calls. Adjust based on API rate limits.

# [OPTIONAL] Bitcoin polling interval (default: 60s - Bitcoin blocks ~10min)
WATCHER_BITCOIN_POLL_MS=60000

# [OPTIONAL] Ethereum polling interval (default: 15s - Eth blocks ~12s)
WATCHER_ETHEREUM_POLL_MS=15000

# [OPTIONAL] BSC polling interval (default: 5s - BSC blocks ~3s)
WATCHER_BSC_POLL_MS=5000

# [OPTIONAL] Tron polling interval (default: 5s - Tron blocks ~3s)
WATCHER_TRON_POLL_MS=5000

# -----------------------------------------------------------------------------
# Watcher Rate Limits (milliseconds between API calls)
# -----------------------------------------------------------------------------
# Prevents hitting API rate limits during polling.

# [OPTIONAL] Delay between Bitcoin API calls
# WATCHER_BITCOIN_RATE_LIMIT_MS=500

# [OPTIONAL] Delay between Etherscan API calls
# WATCHER_ETHEREUM_RATE_LIMIT_MS=200

# [OPTIONAL] Delay between BscScan API calls
# WATCHER_BSC_RATE_LIMIT_MS=200

# [OPTIONAL] Delay between TronGrid API calls
# WATCHER_TRON_RATE_LIMIT_MS=200

# -----------------------------------------------------------------------------
# Per-Chain Watcher Enable/Disable
# -----------------------------------------------------------------------------
# Fine-grained control over which chains are watched.

# [OPTIONAL] Enable Bitcoin watcher (default: true if WATCHER_ENABLED)
# WATCHER_BITCOIN_ENABLED=true

# [OPTIONAL] Enable Ethereum watcher (default: true if WATCHER_ENABLED)
# WATCHER_ETHEREUM_ENABLED=true

# [OPTIONAL] Enable BSC watcher (default: true if WATCHER_ENABLED)
# WATCHER_BSC_ENABLED=true

# [OPTIONAL] Enable Tron watcher (default: true if WATCHER_ENABLED)
# WATCHER_TRON_ENABLED=true

# =============================================================================
# SETTLEMENT (Fiat Payout)
# =============================================================================
# Automatic fiat settlement via Mongoro with Telegram fallback alerts.
# Used in: src/services/payment-engine/settlement/

# [OPTIONAL] Enable automatic fiat settlement
SETTLEMENT_ENABLED=false

# -----------------------------------------------------------------------------
# Mongoro Integration
# -----------------------------------------------------------------------------
# Used in: src/services/payment-engine/settlement/mongoro.service.ts

# [OPTIONAL] Mongoro API URL
MONGORO_API_URL=https://api-biz-dev.mongoro.com/api/v1/openapi

# [REQUIRED if SETTLEMENT_ENABLED=true] Mongoro API token
MONGORO_TOKEN=

# [REQUIRED if SETTLEMENT_ENABLED=true] Mongoro transfer PIN
MONGORO_TRANSFERPIN=

# [OPTIONAL] Webhook URL for Mongoro callbacks
MONGORO_CALLBACK_URL=https://yourapp.com/v1/webhooks/mongoro

# -----------------------------------------------------------------------------
# Telegram Alerts (Fallback for Settlement Failures)
# -----------------------------------------------------------------------------
# Used in: src/services/payment-engine/settlement/telegram.service.ts

# [OPTIONAL] Enable Telegram alerts for settlement failures
TELEGRAM_ALERTS_ENABLED=false

# [REQUIRED if TELEGRAM_ALERTS_ENABLED=true] Telegram bot token
# Get from: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# [REQUIRED if TELEGRAM_ALERTS_ENABLED=true] Telegram chat ID for alerts
TELEGRAM_CHAT_ID=

# =============================================================================
# SECURITY
# =============================================================================
# Used in: src/security/middleware/

# -----------------------------------------------------------------------------
# HMAC Authentication
# -----------------------------------------------------------------------------

# [OPTIONAL] Max age for request timestamps (ms). Prevents replay attacks.
# Default: 5 minutes (300000ms)
HMAC_TIMESTAMP_TOLERANCE_MS=300000

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Used in: src/security/middleware/rateLimit.ts

# [OPTIONAL] Enable rate limiting (recommended for production)
RATE_LIMIT_ENABLED=true

# Standard tier rate limits (default: 100 req/min)
# RATE_LIMIT_STANDARD_WINDOW_MS=60000
# RATE_LIMIT_STANDARD_MAX=100

# Premium tier rate limits (default: 1000 req/min)
# RATE_LIMIT_PREMIUM_WINDOW_MS=60000
# RATE_LIMIT_PREMIUM_MAX=1000

# Unlimited tier rate limits (default: 10000 req/min)
# RATE_LIMIT_UNLIMITED_WINDOW_MS=60000
# RATE_LIMIT_UNLIMITED_MAX=10000

# -----------------------------------------------------------------------------
# IP Whitelist
# -----------------------------------------------------------------------------
# Used in: src/security/middleware/ipWhitelist.ts

# [OPTIONAL] Enable IP whitelist enforcement for API keys with whitelist set
IP_WHITELIST_ENABLED=true

# -----------------------------------------------------------------------------
# Audit Logging
# -----------------------------------------------------------------------------
# Used in: src/security/middleware/auditLog.ts

# [OPTIONAL] Enable request audit logging
AUDIT_LOG_ENABLED=true

# [OPTIONAL] Log full request bodies (WARNING: may expose sensitive data)
# AUDIT_LOG_REQUEST_BODY=false

# [OPTIONAL] Days to retain audit logs before cleanup
# AUDIT_LOG_RETENTION_DAYS=90
